################################################################################
# MyCrew - Git Ignore
# ------------------------------------------------------------------------------
# Arquivos temporários, caches, segredos e dados gerados automaticamente.
################################################################################

################################################################################
# Secrets / Environment
################################################################################

.env
.env.*
!.env.example

################################################################################
# AI / LLM
################################################################################

.aider*
agents/
automation/

################################################################################
# Python
################################################################################

__pycache__/
*.py[cod]
*$py.class

# Compiled extensions
*.so
*.pyd

# Distribution / Packaging
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
share/python-wheels/
*.egg-info/
*.egg

# Virtual Environments
.venv/
venv/
ENV/
env/

# Python tools
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

################################################################################
# Jupyter
################################################################################

.ipynb_checkpoints/

################################################################################
# Logs
################################################################################

*.log
logs/
*.pid
*.seed
*.out
*.err

################################################################################
# Local Databases
################################################################################

*.db
*.sqlite
*.sqlite3

################################################################################
# Docker
################################################################################

docker-data/
docker-volumes/

################################################################################
# VSCode
################################################################################

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

################################################################################
# JetBrains
################################################################################

.idea/

################################################################################
# Operating Systems
################################################################################

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Linux
*~

################################################################################
# NodeJS (caso exista frontend)
################################################################################

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

################################################################################
# Build / Cache
################################################################################

.cache/
tmp/
temp/

################################################################################
# AI Models / Downloads
################################################################################

models/
weights/
checkpoints/

################################################################################
# Backup Files
################################################################################

*.bak
*.backup
*.old
*.orig
*.tmp

################################################################################
# Archives
################################################################################

*.zip
*.tar
*.tar.gz
*.gz
*.rar
*.7z

################################################################################
# Local Configuration
################################################################################

*.local
config.local.*


# v0 sandbox internal files
__v0_runtime_loader.js
__v0_devtools.tsx
__v0_jsx-dev-runtime.ts
.snowflake/
.v0-trash/
.vercel/


# Common ignores
node_modules
