# =====================================================================
# MyCrew - .env.example
# Copie para .env e preencha os valores.
# =====================================================================

# ----- OBRIGATORIAS (sem valor padrao no compose; sobe sem elas) -----
POSTGRES_PASSWORD=                  # senha do Postgres (usuario: litellm por padrao)
LITELLM_MASTER_KEY=                 # chave mestra do proxy LiteLLM (ex: sk-...)
UI_PASSWORD=                        # senha do dashboard web do LiteLLM
N8N_BASIC_AUTH_PASSWORD=            # senha de login do n8n
MYCREW_CRYPTO_KEY=                  # chave de criptografia usada pelo backend

# ----- Usuarios/nomes (tem default no compose, mas pode sobrescrever) -----
POSTGRES_USER=litellm
POSTGRES_DB=litellm
N8N_BASIC_AUTH_USER=admin
UI_USERNAME=admin-litellm

# ----- API keys de provedores externos (opcional, so se for usar) -----
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ----- Open WebUI / n8n integracao -----
OPEN_WEBUI_API_KEY=
OPEN_WEBUI_TOKEN=
OPENWEBUI_AGENT_PREFIX=custom-
N8N_CHAT_FLOW_WEBHOOK=
N8N_KNOWLEDGE_FLOW_WEBHOOK=

# ----- Portas (defaults ja definidos no compose, mudar so se houver conflito) -----
OLLAMA_PORT=11435
OPEN_WEBUI_PORT=3001
QDRANT_PORT=6333
REDIS_PORT=6379
POSTGRES_PORT=5433
LITELLM_PORT=4000
N8N_PORT=5678
DOZZLE_PORT=8085
PORTAINER_PORT=9000
PORTAINER_SSL_PORT=9443
KUMA_PORT=3002
AIDER_PORT=8501
MYCREW_BACKEND_PORT=8082
MYCREW_FRONTEND_PORT=8081

# ----- Diversos -----
TZ=America/Sao_Paulo
AIDER_MODEL=qwen2.5-coder:7b
AIDER_NUM_CTX=16384
QDRANT_COLLECTION=mycrew_agent_kb
QDRANT_TOP_K=4
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=240
OLLAMA_NUM_PREDICT=512
OLLAMA_KEEP_ALIVE=30m

# ----- Profiles ativos (opcional: evita precisar de --profile toda vez) -----
COMPOSE_PROFILES=core,tools