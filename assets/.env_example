# =====================================================================
# MyCrew - .env.example
# Copie para .env e preencha os valores.
# =====================================================================

# ----- OBRIGATORIAS (sem valor padrao no compose; sobe sem elas) -----
POSTGRES_PASSWORD=                   # senha do Postgres (obrigatório)
N8N_BASIC_AUTH_PASSWORD=            # senha de login do n8n (obrigatório)
MYCREW_CRYPTO_KEY=                  # chave de criptografia usada pelo backend (obrigatório)

# ----- Usuarios/nomes (tem default no compose, mas pode sobrescrever) -----
POSTGRES_USER=mycrew
POSTGRES_DB=mycrew
N8N_BASIC_AUTH_USER=admin

# ----- Portas (defaults ja definidos no compose, mudar so se houver conflito) -----
TZ=America/Sao_Paulo
OLLAMA_PORT=11435
QDRANT_PORT=6333
REDIS_PORT=6379
POSTGRES_PORT=5433
N8N_PORT=5678
DOZZLE_PORT=8085
PORTAINER_PORT=9000
PORTAINER_SSL_PORT=9443
KUMA_PORT=3002
MYCREW_BACKEND_PORT=8082
MYCREW_FRONTEND_PORT=8081

# ----- Diversos -----
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=240
OLLAMA_NUM_PREDICT=512
OLLAMA_KEEP_ALIVE=30m
QDRANT_COLLECTION=mycrew_agent_kb
QDRANT_TOP_K=4

# ----- Profiles ativos (opcional: evita precisar de --profile toda vez) -----
COMPOSE_PROFILES=core,tools